# ── Dependencies ──────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js / Build ───────────────────────────────────────────────────
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# ── Environment Files (CRITICAL) ──────────────────────────────────────
# We ignore all local env files to prevent leaking secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# We explicitly DO NOT ignore .env.example so teammates have a template
!.env.example

# ── Testing ───────────────────────────────────────────────────────────
/coverage

# ── Debug / Logs ──────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Misc ──────────────────────────────────────────────────────────────
.DS_Store
*.pem
.vercel
.turbo

# ── IDE / OS ──────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
Thumbs.db
